{
  "app": "python3 app.py",
  "watch": {
    "include": [
      "**"
    ],
    "exclude": [
      "README.md",
      "cdk*.json",
      "requirements.txt",
      "source.bat",
      "**/__init__.py",
      "python/__pycache__",
      "tests"
    ]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:stackRelativeExports": true,
    "@aws-cdk/aws-ids:optimizeDefaultFingerprintProperty": true,
    "@aws-cdk/aws-lambda:stackRelativeLayerAsset": true,
    "@aws-cdk/aws-rds:databaseProxyUniqueResourceName": true,
    "@aws-cdk/aws-codepipeline:crossAccountKeyAliasStackSafeResourceName": true,
    "@aws-cdk/aws-s3:createDefaultLoggingPolicy": true,
    "@aws-cdk/aws-sns-subscriptions:restrictSqsDescryption": true,
    "@aws-cdk/aws-apigateway:disableCloudWatchRole": true,
    "@aws-cdk/core:enablePartitionLiterals": true,
    "@aws-cdk/aws-events:eventsTargetQueueSameAccount": true,
    "@aws-cdk/aws-iam:standardizedServicePrincipals": true,
    "@aws-cdk/aws-ecs:disableExplicitInstanceHostPort": true,
    "@aws-cdk/aws-s3:stepFunctionsDefaultEncryption": true,
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/core:validateSnapshotRemovalPolicy": true,
    "@aws-cdk/aws-codepipeline-actions:2-step-hashes": true,
    "@aws-cdk/aws-s3:serverAccessLogsUseBucketPolicy": true,
    "@aws-cdk/aws-route53-patters:useCertificate": true,
    "@aws-cdk/customresources:installLatestRuntime": false,
    "@aws-cdk/aws-codepipeline:preventCrossAccountQualityIssues": true,
    "@aws-cdk/aws-s3:keepNotificationCloudFormationStack": false,
    "@aws-cdk/aws-ec2:uniqueImdsVars": true,
    "@aws-cdk/aws-iam:importedRoleStackSafeDefaultPolicyName": true,
    "@aws-cdk/aws-s3:groupAndRestrictDefaultPermissions": true,
    "@aws-cdk/aws-efs:defaultEncryptionAtRest": true,
    "@aws-cdk/aws-kms:aliasNameRef": true,
    "@aws-cdk/aws-secretsmanager:useAttachedSecretResourcePolicyLimit": true,
    "@aws-cdk/aws-redshift:columnId": true,
    "@aws-cdk/aws-stepfunctions-tasks:enableStsReplacement": true,
    "@aws-cdk/aws-iam:noBindingByMode": true,
    "@aws-cdk/aws-lambda-eventsources:keepNotificationCloudFormationStack": false,
    "@aws-cdk/aws-lambda:recognizeVersionProps": true
  }
}
